<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Admin Panel' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --primary:#154879;
      --primary-2:#0f3d6a;
      --primary-3:#0b3157;
      --primary-soft:#eaf3fb;
      --primary-soft-2:#f4f8fc;
      --bg:#f5f7fb;
      --text:#111827;
      --muted:#667085;
      --line:#d9e2ec;
      --line-soft:#edf1f6;
      --white:#ffffff;
      --green:#16a34a;
      --green-soft:#ecfdf3;
      --red:#dc2626;
      --red-soft:#fef2f2;
      --amber:#d97706;
      --amber-soft:#fff7ed;
      --shadow:0 20px 50px rgba(21,72,121,.09);
      --shadow-soft:0 10px 28px rgba(15,23,42,.06);
      --radius:14px;
    }
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Inter',Arial,sans-serif}
    html{scroll-behavior:smooth}
    body{min-height:100vh;background:radial-gradient(circle at top right,rgba(21,72,121,.07),transparent 34%),var(--bg);color:var(--text);font-size:14px}
    a{text-decoration:none;color:inherit}
    button,input,select,textarea{font:inherit}
    .admin-page{min-height:100vh;display:flex;align-items:stretch}

    .sidebar{width:315px;min-height:100vh;background:linear-gradient(180deg,var(--primary) 0%,#10436f 42%,#0a3157 100%);color:#fff;flex:0 0 315px;box-shadow:8px 0 24px rgba(0,35,75,.22);position:sticky;top:0;align-self:flex-start;transition:.25s ease;overflow:hidden;z-index:20}
    .admin-page.sidebar-collapsed .sidebar{width:86px;flex-basis:86px}
    .admin-page.sidebar-collapsed .brand-text,.admin-page.sidebar-collapsed .profile-text,.admin-page.sidebar-collapsed .menu-label,.admin-page.sidebar-collapsed .menu-link span:last-child,.admin-page.sidebar-collapsed .menu-title span:last-child,.admin-page.sidebar-collapsed .menu-title::after,.admin-page.sidebar-collapsed .submenu{display:none}
    .admin-page.sidebar-collapsed .brand,.admin-page.sidebar-collapsed .admin-profile{justify-content:center;padding-left:0;padding-right:0}
    .admin-page.sidebar-collapsed .menu-link,.admin-page.sidebar-collapsed .menu-title{justify-content:center;padding-left:0;padding-right:0}

    .brand{min-height:94px;display:flex;align-items:center;gap:14px;padding:16px 22px;border-bottom:1px solid rgba(255,255,255,.10);box-shadow:0 1px 0 rgba(0,0,0,.08)}
    .brand-icon{width:44px;height:44px;min-width:44px;border-radius:9px;background:#fff;color:var(--primary);display:grid;place-items:center;box-shadow:0 10px 20px rgba(0,0,0,.18)}
    .brand-icon svg{width:30px;height:30px}
    .brand-text{font-size:17px;font-weight:800;letter-spacing:.2px;line-height:1.22;white-space:normal}
    .admin-profile{display:flex;align-items:center;gap:18px;padding:28px 24px 30px}
    .avatar{width:62px;height:62px;min-width:62px;border-radius:50%;background:#f8fbff;color:var(--primary);display:grid;place-items:center;box-shadow:inset 0 0 0 1px rgba(21,72,121,.10)}
    .avatar svg{width:39px;height:39px}.profile-text strong{display:block;font-size:16px;margin-bottom:7px}.profile-text span{font-size:14px;opacity:.88}
    .menu-label{font-size:13px;text-transform:uppercase;letter-spacing:.08em;opacity:.70;padding:12px 30px 18px}
    .menu{display:grid;gap:7px;padding:0 14px 24px}.menu-link,.menu-title{display:flex;align-items:center;gap:16px;color:#fff;min-height:58px;border-radius:9px;padding:0 16px;font-weight:600;font-size:16px;transition:.18s ease;cursor:pointer;white-space:nowrap;list-style:none}
    .menu-link:hover,.menu-title:hover{background:rgba(255,255,255,.12)}.menu-link.active{background:linear-gradient(90deg,rgba(68,138,206,.46),rgba(255,255,255,.07));box-shadow:inset 0 0 0 1px rgba(255,255,255,.05)}
    .menu-icon{width:28px;min-width:28px;display:grid;place-items:center}.menu-icon svg{width:28px;height:28px;stroke-width:2}.menu-dropdown{display:grid;gap:7px}.menu-title::-webkit-details-marker{display:none}.menu-title::after{content:'⌄';margin-left:auto;opacity:.8}.menu-dropdown[open] .menu-title::after{transform:rotate(180deg)}.submenu{display:grid;gap:6px;margin:4px 0 4px 45px}.submenu .menu-link{font-size:14px;min-height:42px;padding:0 12px;border-radius:8px}

    .main-content{flex:1;min-width:0;padding:0 30px 34px}.topbar{height:80px;background:linear-gradient(90deg,var(--primary) 0%,#0e4779 62%,#0b3f70 100%);color:#fff;margin:0 -30px 26px;padding:0 30px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 6px 18px rgba(21,72,121,.22)}
    .topbar-left{display:flex;align-items:center;gap:22px}.sidebar-toggle{width:46px;height:46px;border:none;background:transparent;color:#fff;border-radius:10px;display:grid;place-items:center;cursor:pointer}.sidebar-toggle:hover{background:rgba(255,255,255,.13)}.sidebar-toggle svg{width:29px;height:29px}.topbar-title{display:none}.admin-dropdown{display:flex;align-items:center;gap:12px;color:#fff}.admin-mini-avatar{width:40px;height:40px;border-radius:50%;background:#f8fbff;color:var(--primary);display:grid;place-items:center}.admin-mini-avatar svg{width:26px;height:26px}.admin-badge{border:none;background:transparent;color:#fff;font-weight:600;font-size:16px;display:flex;align-items:center;gap:8px;cursor:pointer;padding:10px;border-radius:10px}.admin-badge:hover{background:rgba(255,255,255,.12)}
    .page-heading{display:flex;align-items:flex-start;justify-content:space-between;gap:18px;margin:8px 4px 22px}.page-heading h1{font-size:31px;line-height:1.1;font-weight:800;color:#111827;margin-bottom:8px}.page-heading p{font-size:18px;color:#5b6778}.breadcrumb{font-size:16px;color:#5f6b7a;display:flex;gap:10px;align-items:center;margin-top:15px;white-space:nowrap}.breadcrumb a{color:var(--primary);font-weight:600}.breadcrumb .divider{color:#98a2b3}

    .stats-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:20px}.stat-card,.table-card,.form-card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow-soft)}.stat-card{padding:24px;position:relative;overflow:hidden}.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--primary)}.stat-card.red::before{background:var(--red)}.stat-card.purple::before{background:#7c3aed}.stat-card.green::before{background:var(--green)}.stat-title{color:#667085;font-weight:700;margin-bottom:14px}.stat-number{font-size:42px;font-weight:800;line-height:1;margin-bottom:9px}.stat-desc{color:#7a8797;font-size:13px}

    .table-card{padding:24px 7px 12px;overflow:hidden}.table-top{display:flex;align-items:center;justify-content:space-between;gap:16px;margin:0 18px 20px}.table-top h2{font-size:20px;font-weight:800}.toolbar{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;margin:0 16px 26px}.filter-left,.filter-right,.search-form,.filter-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap}.control,.search-form input,.search-form select,.filter-row input,.filter-row select{height:42px;border:1px solid #d4dde8;border-radius:6px;background:#fff;color:#344054;padding:0 14px;outline:none;min-width:176px}.search-box{position:relative}.search-box input{height:42px;width:296px;border:1px solid #d4dde8;border-radius:6px;padding:0 42px 0 14px;outline:none;color:#344054}.search-box svg{position:absolute;right:12px;top:50%;transform:translateY(-50%);width:22px;height:22px;color:#475467}.control:focus,.search-box input:focus,.search-form input:focus,.search-form select:focus,.filter-row input:focus,.filter-row select:focus,.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--primary);box-shadow:0 0 0 4px rgba(21,72,121,.12)}
    .btn-primary,.btn-secondary,.btn-danger,.btn-warning,.btn-success,.btn-view{border:none;border-radius:6px;padding:11px 16px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;justify-content:center;gap:7px;cursor:pointer;font-size:14px;line-height:1;white-space:nowrap;transition:.15s}.btn-primary{background:var(--primary);color:#fff;box-shadow:0 8px 18px rgba(21,72,121,.20)}.btn-primary:hover{background:#0f3d6a}.btn-secondary{background:#fff;color:#344054;border:1px solid #d4dde8}.btn-secondary:hover{background:#f7fafc}.btn-success{background:#20a052;color:#fff}.btn-success:hover{background:#178541}.btn-danger{background:#d9272e;color:#fff}.btn-danger:hover{background:#b91c1c}.btn-warning{background:var(--primary);color:#fff}.btn-view{width:40px;height:38px;padding:0;border:1px solid #d4dde8;background:#fff;color:#344054}.btn-view:hover{background:var(--primary-soft);color:var(--primary)}

    .table-wrap{overflow:auto;border-top:0}table{width:100%;min-width:1080px;border-collapse:separate;border-spacing:0}table thead th{background:linear-gradient(180deg,#15568d,var(--primary));color:#fff;text-align:left;font-size:15px;font-weight:800;padding:19px 17px;border-bottom:1px solid #0d3d68}table thead th:first-child{border-top-left-radius:6px}table thead th:last-child{border-top-right-radius:6px}table tbody td{padding:18px 17px;border-bottom:1px solid #e4eaf1;font-size:14px;color:#101828;vertical-align:middle}table tbody tr:hover{background:#f8fbff}table small{display:block;color:#667085;font-size:13px;margin-top:7px;line-height:1.3}table .center{text-align:center}table .muted{color:#475467}
    .badge{display:inline-flex;align-items:center;justify-content:center;padding:6px 9px;border-radius:4px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.02em;border:1px solid transparent}.badge-yellow{background:#fffbeb;color:#d97706;border-color:#f3bd5d}.badge-green{background:#ecfdf3;color:#16803f;border-color:#8cd7a8}.badge-red{background:#fff1f2;color:#d01c1f;border-color:#f6a7ad}.badge-blue{background:var(--primary-soft);color:var(--primary);border-color:#b9d8ee}.badge-gray{background:#f2f4f7;color:#475467;border-color:#e4e7ec}.actions{display:flex;align-items:center;gap:7px;flex-wrap:nowrap}.inline{display:inline}.empty-state{text-align:center;padding:40px 12px!important;color:#667085!important}.table-footer{height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;color:#5f6b7a;font-size:14px}.pagination{display:flex;gap:6px;align-items:center}.page-btn{width:34px;height:34px;border-radius:5px;border:1px solid #d4dde8;background:#fff;color:#475467;display:grid;place-items:center}.page-btn.active{background:var(--primary);color:#fff;border-color:var(--primary)}.page-btn.page-nav{width:auto;min-width:64px;padding:0 12px;font-weight:700}.page-btn.disabled{opacity:.45;cursor:not-allowed;background:#f8fafc}.page-input{width:58px;height:34px;border:1px solid var(--primary);border-radius:5px;text-align:center;font-weight:800;color:var(--primary);outline:none}.page-input:focus{box-shadow:0 0 0 4px rgba(21,72,121,.12)}.page-text{padding:0 6px;color:#667085;font-weight:700}

    .form-card{width:100%;max-width:780px;padding:28px}.form-group{margin-bottom:18px}.form-group label{display:block;margin-bottom:9px;font-size:14px;font-weight:800}.form-group input,.form-group select,.form-group textarea{width:100%;height:50px;border:1px solid #d4dde8;border-radius:9px;padding:0 14px;outline:none;background:#fff}.form-group textarea{height:120px;padding-top:12px;resize:vertical}.form-actions{display:flex;gap:12px;margin-top:24px}
    .popup-alert{position:fixed;top:22px;right:22px;z-index:1000;width:min(390px,calc(100% - 32px));padding:15px 17px;border-radius:14px;color:#fff;box-shadow:0 18px 35px rgba(15,23,42,.22);font-weight:700;animation:popupSlide .35s ease,popupHide .35s ease 4.6s forwards}.popup-success{background:linear-gradient(135deg,#22c55e,#15803d)}.popup-error{background:linear-gradient(135deg,#ef4444,#b91c1c)}.logout-modal{position:fixed;inset:0;z-index:1200;display:none;align-items:center;justify-content:center;background:rgba(15,23,42,.45);padding:18px}.logout-modal.show{display:flex}.logout-box{width:min(420px,100%);background:#fff;border-radius:18px;padding:26px;box-shadow:0 24px 50px rgba(15,23,42,.25)}.logout-box h2{font-size:22px;margin-bottom:8px}.logout-box p{color:#667085;line-height:1.5;margin-bottom:24px}.logout-actions{display:flex;gap:12px;justify-content:flex-end}.btn-cancel,.btn-logout{height:44px;border-radius:10px;padding:0 18px;font-weight:800;cursor:pointer}.btn-cancel{border:1px solid #d4dde8;background:#fff;color:#475467}.btn-logout{border:none;background:var(--red);color:#fff}
    @keyframes popupSlide{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}@keyframes popupHide{to{opacity:0;transform:translateY(-12px);visibility:hidden}}
    @media(max-width:1100px){.stats-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.sidebar{width:270px;flex-basis:270px}.page-heading{flex-direction:column}.breadcrumb{margin-top:0}.toolbar{align-items:stretch}.filter-left,.filter-right{width:100%}.search-box input{width:100%}.search-box{flex:1}}
    @media(max-width:780px){.admin-page{display:block}.sidebar{position:relative;width:100%;min-height:auto;flex-basis:auto}.admin-page.sidebar-collapsed .sidebar{width:100%;height:0}.main-content{padding:0 16px 24px}.topbar{margin:0 -16px 20px;padding:0 16px}.page-heading h1{font-size:26px}.page-heading p{font-size:15px}.stats-grid{grid-template-columns:1fr}.table-card{padding-top:18px}.toolbar,.filter-left,.filter-right{display:grid;grid-template-columns:1fr}.control,.search-box input{width:100%;min-width:0}.table-footer{flex-direction:column;height:auto;padding:14px;gap:12px;align-items:flex-start}.admin-badge span{display:none}}

    .settings-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.settings-card{background:#fff;border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow-soft);padding:24px;display:flex;flex-direction:column;gap:14px;min-height:215px}.settings-card h2{font-size:20px;font-weight:800;color:#101828}.settings-card p{color:#667085;line-height:1.55}.settings-card.wide{grid-column:span 2}.settings-icon{width:52px;height:52px;border-radius:14px;background:var(--primary-soft);color:var(--primary);display:grid;place-items:center;font-size:25px}.settings-icon.big{width:68px;height:68px;font-size:32px}.settings-info{display:grid;gap:10px;margin-top:6px}.settings-info div{display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid var(--line-soft);background:var(--primary-soft-2);border-radius:10px;padding:12px}.settings-info span{color:#667085}.settings-info strong{color:var(--primary);word-break:break-all}.profile-card{grid-row:span 2}.setting-note{padding:14px 16px;border-radius:12px;background:var(--primary-soft);color:var(--primary);font-weight:700;line-height:1.5}
    @media(max-width:1100px){.settings-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.settings-card.wide{grid-column:span 1}}
    @media(max-width:600px){.settings-grid{grid-template-columns:1fr}.settings-card{min-height:auto;padding:18px}.settings-info div{display:block}.settings-info span{display:block;margin-bottom:6px}.brand{height:auto;min-height:74px}.brand-text{font-size:16px}.admin-profile{padding:18px 20px}.menu{padding-bottom:14px}.menu-link,.menu-title{min-height:50px;font-size:14px}.topbar{height:66px}.page-heading{margin-bottom:16px}.table-top{align-items:flex-start;flex-direction:column}.form-actions{flex-direction:column}.form-actions a,.form-actions button,.btn-primary,.btn-secondary,.btn-danger,.btn-warning,.btn-success{width:100%}.stat-number{font-size:34px}table{min-width:880px}}

  </style>
</head>
<body>
