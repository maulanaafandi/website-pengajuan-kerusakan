<%- include('../partials/head', { title: 'Kelola Rekomendasi' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'rekomendasi' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Kelola Rekomendasi', pageSubtitle: 'AI hanya untuk membuat rekomendasi berdasarkan semua laporan dan inventaris.' }) %>

    <div class="table-card" style="margin-bottom:22px">
      <div class="table-top">
        <div>
          <h2>Generate Rekomendasi AI</h2>
          <p style="color:#667085;margin-top:6px">AI membaca seluruh laporan user + data inventaris, lalu menampilkan hasil sementara. Klik Simpan jika hasilnya sudah sesuai.</p>
        </div>
        <div class="actions" style="gap:10px">
          <form method="POST" action="/admin/rekomendasi/generate-ai" class="inline">
            <button class="btn-primary" type="submit" onclick="return confirm('Generate rekomendasi AI berdasarkan semua laporan dan inventaris?')">Generate Rekomendasi AI</button>
          </form>
          <a href="/admin/rekomendasi/create" class="btn-secondary">+ Tambah Manual</a>
        </div>
      </div>

      <% if (aiResults && aiResults.length) { %>
        <div class="ai-box">
          <div class="ai-header">
            <div>
              <h3>Hasil AI Sementara</h3>
              <p>Data di bawah ini belum masuk database. Review dulu, lalu klik Simpan ke Database.</p>
            </div>
            <div class="actions">
              <form method="POST" action="/admin/rekomendasi/save-ai" class="inline">
                <button class="btn-success" type="submit" onclick="return confirm('Simpan semua hasil AI ke tabel rekomendasi?')">Simpan ke Database</button>
              </form>
              <form method="POST" action="/admin/rekomendasi/clear-ai" class="inline">
                <button class="btn-danger" type="submit" onclick="return confirm('Buang hasil sementara AI?')">Buang</button>
              </form>
            </div>
          </div>

          <div class="ai-grid">
            <% aiResults.forEach((item, index) => { %>
              <article class="ai-card">
                <div class="ai-number"><%= index + 1 %></div>
                <div class="ai-content">
                  <div class="ai-room"><%= item.nama_ruangan || '-' %> <span><%= item.lokasi || '-' %></span></div>
                  <h4><%= item.barang_rekomendasi_diajukan || '-' %></h4>
                  <p><%= item.alasan || '-' %></p>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="table-card">
      <div class="table-top"><h2>Data Rekomendasi Tersimpan</h2></div>
      <form method="GET" class="search-form">
        <input type="text" name="search" placeholder="Cari ruangan, lokasi, atau barang rekomendasi..." value="<%= search || '' %>">
        <button class="btn-primary" type="submit">Cari</button>
        <a class="btn-secondary" href="/admin/rekomendasi">Reset</a>
      </form>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Ruangan</th>
              <th>Lokasi</th>
              <th>Barang Rekomendasi</th>
              <th>Alasan</th>
              <th>Tanggal</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (rekomendasi.length === 0) { %>
              <tr><td colspan="7" class="empty-state">Data rekomendasi kosong</td></tr>
            <% } %>
            <% rekomendasi.forEach(item => { %>
              <tr>
                <td><%= item.id_rekomendasi %></td>
                <td>
                  <strong><%= item.nama_ruangan || '-' %></strong>
                  <small><%= item.kode_ruangan || '-' %></small>
                </td>
                <td><span class="badge badge-blue"><%= item.lokasi || '-' %></span></td>
                <td><%= item.barang_rekomendasi_diajukan || item.nama_barang || '-' %></td>
                <td style="max-width:360px;white-space:normal;line-height:1.5"><%= item.alasan || '-' %></td>
                <td><%= formatDate(item.tanggal) || '-' %></td>
                <td>
                  <div class="actions">
                    <a href="/admin/rekomendasi/edit/<%= item.id_rekomendasi %>" class="btn-warning">Edit</a>
                    <form class="inline" action="/admin/rekomendasi/delete/<%= item.id_rekomendasi %>" method="POST" data-confirm-message="Rekomendasi <%= item.barang_rekomendasi_diajukan || item.nama_barang || 'ini' %> akan dihapus permanen.">
                      <button type="submit" class="btn-danger">Hapus</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <%- include('../partials/pagination', { pagination }) %>
    </div>

    <style>
      .ai-box{margin:18px;border:1px solid #bfdbfe;background:#eff6ff;border-radius:16px;padding:18px}
      .ai-header{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:16px}.ai-header h3{font-size:20px}.ai-header p{color:#475569;margin-top:5px}.ai-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.ai-card{display:flex;gap:14px;background:#fff;border:1px solid #dbeafe;border-radius:14px;padding:16px;box-shadow:0 8px 18px rgba(15,23,42,.05)}.ai-number{width:34px;height:34px;border-radius:10px;background:#154879;color:#fff;display:grid;place-items:center;font-weight:800;flex:0 0 34px}.ai-room{font-weight:800;color:#154879;margin-bottom:8px}.ai-room span{font-size:12px;background:#e0f2fe;color:#0369a1;border-radius:999px;padding:4px 8px;margin-left:6px}.ai-content h4{font-size:16px;margin-bottom:8px}.ai-content p{color:#475569;line-height:1.55}@media(max-width:900px){.ai-header{display:block}.ai-header .actions{margin-top:12px}.ai-grid{grid-template-columns:1fr}}
    </style>
  </section>
<%- include('../partials/footer') %>
