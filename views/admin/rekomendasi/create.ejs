<%- include('../partials/head', { title: 'Tambah Rekomendasi' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'rekomendasi' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Tambah Rekomendasi', pageSubtitle: 'Form tambah rekomendasi pengajuan barang manual.' }) %>
    <form action="/admin/rekomendasi/create" method="POST" class="form-card">
      <div class="form-group">
        <label>Ruangan</label>
        <select name="id_ruangan" required>
          <option value="">Pilih Ruangan</option>
          <% ruangan.forEach(r => { %>
            <option value="<%= r.id_ruangan %>"><%= r.nama_ruangan %> - <%= r.kode_ruangan %> - <%= r.lokasi %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>Barang Rekomendasi Diajukan</label><input type="text" name="barang_rekomendasi_diajukan" required></div>
      <div class="form-group"><label>Nama Barang Utama</label><input type="text" name="nama_barang" placeholder="Opsional, boleh sama dengan barang rekomendasi"></div>
      <div class="form-group"><label>Alasan</label><textarea name="alasan" placeholder="Contoh: Banyak laporan kerusakan pada barang tersebut."></textarea></div>
      <div class="form-group"><label>Tanggal</label><input type="date" name="tanggal" required></div>
      <div class="form-actions"><button type="submit" class="btn-primary">Simpan</button><a href="/admin/rekomendasi" class="btn-secondary">Kembali</a></div>
    </form>
  </section>
<%- include('../partials/footer') %>
