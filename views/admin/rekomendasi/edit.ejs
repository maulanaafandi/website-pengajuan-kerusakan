<%- include('../partials/head', { title: 'Edit Rekomendasi' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'rekomendasi' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Edit Rekomendasi', pageSubtitle: 'Ubah data rekomendasi pengajuan barang.' }) %>
    <form action="/admin/rekomendasi/edit/<%= item.id_rekomendasi %>" method="POST" class="form-card">
      <input type="hidden" name="_method" value="PATCH">
      <div class="form-group">
        <label>Ruangan</label>
        <select name="id_ruangan" required>
          <% ruangan.forEach(r => { %>
            <option value="<%= r.id_ruangan %>" <%= Number(item.id_ruangan) === Number(r.id_ruangan) ? 'selected' : '' %>><%= r.nama_ruangan %> - <%= r.kode_ruangan %> - <%= r.lokasi %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group"><label>Barang Rekomendasi Diajukan</label><input type="text" name="barang_rekomendasi_diajukan" value="<%= item.barang_rekomendasi_diajukan || '' %>" required></div>
      <div class="form-group"><label>Nama Barang Utama</label><input type="text" name="nama_barang" value="<%= item.nama_barang || '' %>"></div>
      <div class="form-group"><label>Alasan</label><textarea name="alasan"><%= item.alasan || '' %></textarea></div>
      <div class="form-group"><label>Tanggal</label><input type="date" name="tanggal" value="<%= formatDate(item.tanggal) %>" required></div>
      <div class="form-actions"><button type="submit" class="btn-primary">Update</button><a href="/admin/rekomendasi" class="btn-secondary">Kembali</a></div>
    </form>
  </section>
<%- include('../partials/footer') %>
