<%- include('../partials/head', { title: 'Kelola Ruangan' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'ruangan' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Kelola Ruangan', pageSubtitle: 'Tambah, edit, hapus, dan cari data ruangan.' }) %>
    <div class="table-card">
      <div class="table-top"><h2>Data Ruangan</h2><a href="/admin/ruangan/create" class="btn-primary">+ Tambah Ruangan</a></div>
      <form method="GET" class="search-form"><input type="text" name="search" placeholder="Cari nama, kode, atau lokasi..." value="<%= search || '' %>"><button class="btn-primary" type="submit">Cari</button><a class="btn-secondary" href="/admin/ruangan">Reset</a></form>
      <table><thead><tr><th>ID</th><th>Nama Ruangan</th><th>Kode Ruangan</th><th>Lokasi</th><th>Aksi</th></tr></thead><tbody>
      <% if (ruangan.length === 0) { %><tr><td colspan="5" class="empty-state">Data ruangan kosong</td></tr><% } %>
      <% ruangan.forEach(item => { %><tr><td><%= item.id_ruangan %></td><td><%= item.nama_ruangan %></td><td><%= item.kode_ruangan %></td><td><span class="badge badge-blue"><%= item.lokasi %></span></td><td><div class="actions"><a href="/admin/ruangan/edit/<%= item.id_ruangan %>" class="btn-warning">Edit</a><form class="inline" action="/admin/ruangan/delete/<%= item.id_ruangan %>" method="POST"><button type="submit" onclick="return confirm('Yakin hapus ruangan ini?')" class="btn-danger">Hapus</button></form></div></td></tr><% }) %>
      </tbody></table>
    </div>
  </section>
<%- include('../partials/footer') %>
