<%- include('../partials/head', { title: 'Detail Laporan User' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'laporan' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Detail Laporan User', pageSubtitle: 'Lihat detail laporan dan riwayat audit.' }) %>

    <div class="detail-grid" style="display:grid;grid-template-columns:1.2fr .8fr;gap:20px;align-items:start">
      <div class="form-card" style="max-width:100%">
        <div class="table-top" style="margin:0 0 20px 0">
          <h2>Informasi Laporan</h2>
          <div class="actions">
            <button type="button" class="btn-danger" id="auditToggle" title="Riwayat audit laporan">!</button>
            <a href="/admin/laporan" class="btn-secondary">Kembali</a>
          </div>
        </div>

        <div class="info-list" style="display:grid;gap:14px">
          <div class="info-row"><span>User</span><strong><%= laporan.nama_pelapor || laporan.email || '-' %></strong></div>
          <div class="info-row"><span>Email</span><strong><%= laporan.email || '-' %></strong></div>
          <div class="info-row"><span>Role</span><strong><%= laporan.role || '-' %></strong></div>
          <div class="info-row"><span>Tanggal</span><strong><%= laporan.tanggal || '-' %> <%= laporan.jam || '' %></strong></div>
          <div class="info-row"><span>Kategori</span><strong><%= laporan.kategori || '-' %></strong></div>
          <div class="info-row"><span>Status</span><strong><%= laporan.status || '-' %></strong></div>
          <div class="info-row"><span>Prioritas</span><strong><%= laporan.prioritas || '-' %></strong></div>
          <div class="info-row"><span>Ruangan</span><strong><%= laporan.nama_ruangan || '-' %> (<%= laporan.lokasi || '-' %>)</strong></div>
          <div class="info-row"><span>Lantai</span><strong><%= laporan.lantai || '-' %></strong></div>
          <div class="info-row"><span>Kode Ruangan</span><strong><%= laporan.kode_ruangan || '-' %></strong></div>
          <div class="info-row"><span>Barang</span><strong><%= laporan.nama_barang || '-' %></strong></div>
          <div class="info-row"><span>Kode Barang</span><strong><%= laporan.kode_barang || '-' %></strong></div>
          <div class="info-row"><span>NUP</span><strong><%= laporan.nup || '-' %></strong></div>
          <div class="info-row"><span>Merk</span><strong><%= laporan.merk || '-' %></strong></div>
          <%
            const kondisiRaw = String(laporan.kondisi || '-')
            const kondisiNumber = parseFloat(kondisiRaw.replace(',', '.'))
            const kondisiText = Number.isNaN(kondisiNumber)
              ? kondisiRaw
              : kondisiNumber.toFixed(2).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1')
            const kondisiDisplay = Number.isNaN(kondisiNumber) ? kondisiRaw : `${kondisiText}%`
          %>
          <div class="info-row"><span>Kondisi</span><strong><%= kondisiDisplay %></strong></div>
          <div class="info-row block"><span>Deskripsi Pelapor</span><p><%= laporan.deskripsi || laporan.keterangan || '-' %></p></div>
          <div class="info-row block"><span>Keterangan Laporan</span><p><%= laporan.keterangan_admin || '-' %></p></div>
        </div>
      </div>

      <div style="display:grid;gap:20px">
        <div class="form-card" id="auditPanel" style="max-width:100%;display:none">
          <h2 style="margin-bottom:14px">Trigger Audit Laporan</h2>
          <% if (!auditLaporan || auditLaporan.length === 0) { %>
            <div class="empty-state" style="border:1px dashed #d0d5dd;border-radius:14px">Belum ada data audit untuk laporan ini.</div>
          <% } else { %>
            <div class="info-list" style="display:grid;gap:12px">
              <% auditLaporan.forEach(audit => { %>
                <div class="info-row block">
                  <span><%= audit.waktu %> - <%= audit.action || '-' %></span>
                  <p><strong>Data Lama:</strong> <%= audit.data_lama || '-' %></p>
                  <p><strong>Data Baru:</strong> <%= audit.data_baru || '-' %></p>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <div class="form-card" style="max-width:100%">
          <h2 style="margin-bottom:14px">Foto Bukti</h2>
          <% if (laporan.bukti_foto) { %>
            <img src="/uploads/<%= laporan.bukti_foto %>" alt="Bukti laporan" style="width:100%;border-radius:14px;border:1px solid #e5e7eb;object-fit:cover;max-height:320px">
          <% } else { %>
            <div class="empty-state" style="border:1px dashed #d0d5dd;border-radius:14px">Tidak ada foto bukti</div>
          <% } %>
        </div>

        <div class="form-card" style="max-width:100%">
          <h2 style="margin-bottom:14px">Akses Admin</h2>
          <div class="empty-state" style="border:1px dashed #d0d5dd;border-radius:14px">
            Admin hanya dapat melihat laporan. Perubahan status dan keterangan laporan dilakukan oleh role operasional.
          </div>
        </div>
      </div>
    </div>

    <style>
      .info-row{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:13px 14px;border:1px solid #edf1f6;background:#f8fafc;border-radius:12px}
      .info-row span{color:#667085;font-weight:700}.info-row strong{color:#111827;text-align:right}.info-row.block{display:block}.info-row.block p{margin-top:10px;line-height:1.7;color:#111827}
      @media(max-width:980px){.detail-grid{grid-template-columns:1fr!important}}
    </style>
    <script>
      document.getElementById('auditToggle').addEventListener('click', function () {
        var panel = document.getElementById('auditPanel')
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none'
      })
    </script>
  </section>
<%- include('../partials/footer') %>
