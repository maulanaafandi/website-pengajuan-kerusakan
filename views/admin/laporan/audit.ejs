<%- include('../partials/head', { title: 'Trigger Laporan' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'audit-laporan' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Trigger Laporan', pageSubtitle: 'Lihat hasil trigger dari perubahan data laporan.' }) %>
    <div class="table-card">
      <form method="GET" action="/admin/laporan/audit" class="toolbar">
        <div class="filter-left">
          <a href="/admin/laporan" class="btn-secondary">Kembali ke Laporan</a>
        </div>
        <div class="filter-right">
          <div class="search-box">
            <input type="text" name="search" placeholder="Cari kode laporan/user..." value="<%= search || '' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          </div>
          <button class="btn-primary" type="submit">Cari</button>
          <% if (search && search.length) { %>
            <a href="/admin/laporan/audit" class="btn-secondary">Reset</a>
          <% } %>
        </div>
      </form>

      <% if (!auditLaporan || auditLaporan.length === 0) { %>
        <div class="empty-state">Belum ada hasil trigger yang tercatat.</div>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th style="width:58px">No</th>
                <th>Kode Laporan</th>
                <th>Pelapor</th>
                <th>Update Terakhir</th>
                <th>Total Trigger</th>
                <th class="center">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% auditLaporan.forEach((audit, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><strong><%= audit.kode_laporan || '-' %></strong></td>
                  <td>
                    <strong><%= audit.nama_pelapor || '-' %></strong>
                    <small><%= audit.email_pelapor || '-' %></small>
                  </td>
                  <td><%= audit.waktu_terakhir || '-' %></td>
                  <td><%= audit.total_audit || 0 %></td>
                  <td>
                    <div class="actions" style="justify-content:center">
                      <a href="/admin/laporan/audit/<%= audit.id_laporan %>" class="btn-view" title="Detail trigger laporan">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" style="width:20px;height:20px"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </section>
<%- include('../partials/footer') %>
