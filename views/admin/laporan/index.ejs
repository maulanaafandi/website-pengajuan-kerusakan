<%- include('../partials/head', { title: 'Laporan' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: status === 'selesai' ? 'laporan-selesai' : 'laporan' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Laporan', pageSubtitle: 'Pantau laporan kerusakan dan kehilangan inventaris.' }) %>

    <div class="table-card">
      <form method="GET" action="/admin/laporan" class="toolbar">
        <div class="filter-left">
          <select name="status" class="control">
            <option value="">Semua Status</option>
            <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="diproses_internal" <%= status === 'diproses_internal' ? 'selected' : '' %>>Diproses Internal</option>
            <option value="diproses_eksternal" <%= status === 'diproses_eksternal' ? 'selected' : '' %>>Diproses Eksternal</option>
            <option value="ditolak" <%= status === 'ditolak' ? 'selected' : '' %>>Ditolak</option>
            <option value="selesai" <%= status === 'selesai' ? 'selected' : '' %>>Selesai</option>
          </select>
          <input type="date" name="tanggal" class="control" value="<%= tanggal || '' %>" aria-label="Pilih tanggal">
          <button class="btn-primary" type="submit">Filter</button>
          <% if ((search && search.length) || (status && status.length) || (tanggal && tanggal.length)) { %>
            <a href="/admin/laporan" class="btn-secondary">Reset</a>
          <% } %>
        </div>
        <div class="filter-right">
          <div class="search-box">
            <input type="text" name="search" placeholder="Cari kode laporan/user..." value="<%= search || '' %>">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          </div>
        </div>
      </form>

      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width:58px">No</th>
              <th>Kode Laporan</th>
              <th>User</th>
              <th>Tanggal</th>
              <th>Barang</th>
              <th>Kondisi</th>
              <th>Status</th>
              <th class="center">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (!laporan || laporan.length === 0) { %>
              <tr>
                <td colspan="8" class="empty-state">Data pengajuan masih kosong</td>
              </tr>
            <% } %>

            <% laporan.forEach((item, index) => { %>
              <% const statusValue = item.status || 'pending'; %>
              <% const statusClass = statusValue === 'selesai' ? 'badge-green' : statusValue === 'ditolak' ? 'badge-red' : 'badge-yellow'; %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= item.kode_laporan || '-' %></td>
                <td>
                  <strong><%= item.email || '-' %></strong>
                  <small><%= item.role ? (item.role.charAt(0).toUpperCase() + item.role.slice(1)) : 'Administrator' %></small>
                </td>
                <td>
                  <span><%= formatDate(item.tanggal) || '-' %></span>
                </td>
              <td>
                <strong><%= item.nama_barang || '-' %></strong>
                <small><%= item.kode_barang || '-' %><% if (item.merk) { %> - <%= item.merk %><% } %></small>
              </td>
                <%
                  const kondisiRaw = String(item.jumlah || item.kondisi || '-')
                  const kondisiNumber = parseFloat(kondisiRaw.replace(',', '.'))
                  const kondisiText = Number.isNaN(kondisiNumber)
                    ? kondisiRaw
                    : kondisiNumber.toFixed(2).replace(/\.00$/, '').replace(/(\.\d)0$/, '$1')
                  const kondisiDisplay = Number.isNaN(kondisiNumber) ? kondisiRaw : `${kondisiText}%`
                %>
                <td><%= kondisiDisplay %></td>
                <td><span class="badge <%= statusClass %>"><%= statusValue %></span></td>
                <td>
                  <div class="actions" style="justify-content:center">
                    <a href="/admin/laporan/detail/<%= item.id_laporan %>" class="btn-view" title="Detail laporan user">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" style="width:20px;height:20px"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="table-footer">
        <span>Menampilkan 1 sampai <%= laporan && laporan.length ? laporan.length : 0 %> dari <%= laporan && laporan.length ? laporan.length : 0 %> data</span>
        <div class="pagination">
          <span class="page-btn">‹</span>
          <span class="page-btn active">1</span>
          <span class="page-btn">›</span>
        </div>
      </div>
    </div>
  </section>
<%- include('../partials/footer') %>
