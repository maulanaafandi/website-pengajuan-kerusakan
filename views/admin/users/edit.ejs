<%- include('../partials/head', { title: 'Edit User' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'users' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Edit User', pageSubtitle: 'Ubah data akun pengguna.' }) %>
    <form action="/admin/users/edit/<%= user.id_user %>" method="POST" class="form-card">
      <input type="hidden" name="_method" value="PATCH">
      <div class="form-group"><label>Email</label><input type="email" name="email" value="<%= user.email %>" required></div>
      <div class="form-group"><label>Role</label><select name="role" required><% ['mahasiswa','dosen','satpam','tendik','plp','admin'].forEach(role => { %><option value="<%= role %>" <%= user.role === role ? 'selected' : '' %>><%= role %></option><% }) %></select></div>
      <div class="form-group"><label>Kaleb</label><select name="kaleb"><option value="0" <%= user.kaleb === '0' ? 'selected' : '' %>>0</option><option value="1" <%= user.kaleb === '1' ? 'selected' : '' %>>1</option></select></div>
      <div class="form-actions"><button type="submit" class="btn-primary">Update</button><a href="/admin/users" class="btn-secondary">Kembali</a></div>
    </form>
  </section>
<%- include('../partials/footer') %>
