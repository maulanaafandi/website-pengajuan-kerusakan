<%- include('../partials/head', { title: 'Kelola User' }) %>
<main class="admin-page" id="adminPage">
  <%- include('../partials/sidebar', { active: 'users' }) %>
  <section class="main-content">
    <%- include('../partials/topbar', { pageTitle: 'Kelola User', pageSubtitle: 'Kelola akun dan status aktivasi pengguna.' }) %>
    <div class="table-card">
      <form method="GET" class="search-form"><input type="text" name="search" placeholder="Cari nama, email, role, kaleb, atau status..." value="<%= search || '' %>"><button class="btn-primary" type="submit">Cari</button><a class="btn-secondary" href="/admin/users">Reset</a></form>
      <table><thead><tr><th>No</th><th>Nama</th><th>Email</th><th>Role</th><th>Kaleb</th><th>Status</th><th>Aksi</th></tr></thead><tbody>
      <% if (users.length === 0) { %><tr><td colspan="7" class="empty-state">Data user kosong</td></tr><% } %>
      <% users.forEach(user => { %><tr><td><%= user.id_user %></td><td><%= user.nama || '-' %></td><td><%= user.email %></td><td><span class="badge badge-blue"><%= user.role %></span></td><td><span class="badge <%= String(user.kaleb) === '1' ? 'badge-green' : 'badge-gray' %>"><%= user.kaleb %></span></td><td><span class="badge <%= user.status === 'aktif' ? 'badge-green' : user.status === 'nonaktif' ? 'badge-red' : 'badge-yellow' %>"><%= user.status || 'proses' %></span></td><td><% if (user.role === 'admin') { %><span class="badge badge-gray">Terkunci</span><% } else { %><div class="actions"><form class="inline" action="/admin/users/status/<%= user.id_user %>" method="POST"><input type="hidden" name="_method" value="PATCH"><select name="status" class="control" style="min-width:118px;height:36px"><option value="proses" <%= user.status === 'proses' ? 'selected' : '' %>>proses</option><option value="aktif" <%= user.status === 'aktif' ? 'selected' : '' %>>aktif</option><option value="nonaktif" <%= user.status === 'nonaktif' ? 'selected' : '' %>>nonaktif</option></select><button type="submit" class="btn-warning">Update Status</button></form><% if (user.status === 'nonaktif') { %><form class="inline" action="/admin/users/delete/<%= user.id_user %>" method="POST" data-confirm-message="User <%= user.email || 'ini' %> akan dihapus permanen."><input type="hidden" name="_method" value="DELETE"><button type="submit" class="btn-danger">Hapus</button></form><% } %></div><% } %></td></tr><% }) %>
      </tbody></table>
      <%- include('../partials/pagination', { pagination }) %>
    </div>
  </section>
<%- include('../partials/footer') %>
