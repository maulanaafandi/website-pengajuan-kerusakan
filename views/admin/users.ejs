<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar Akun</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body{
      min-height: 100vh;
      background: #f1f5f9;
      color: #0f172a;
    }

    .admin-page{
      min-height: 100vh;
      display: flex;
    }

    .sidebar{
      width: 260px;
      background: #ffffff;
      border-right: 1px solid #e2e8f0;
      padding: 28px 20px;
      flex: 0 0 auto;
      transition: 0.25s;
      overflow: hidden;
    }

    .admin-page.sidebar-collapsed .sidebar{
      width: 0;
      padding-left: 0;
      padding-right: 0;
      border-right: none;
    }

    .brand{
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 32px;
    }

    .menu{
      display: grid;
      gap: 10px;
    }

    .menu-link{
      display: block;
      text-decoration: none;
      color: #475569;
      font-size: 15px;
      font-weight: 600;
      padding: 13px 15px;
      border-radius: 14px;
      transition: 0.2s;
    }

    .menu-link.active,
    .menu-link:hover{
      background: #eff6ff;
      color: #2563eb;
    }

    .menu-dropdown{
      display: grid;
      gap: 8px;
    }

    .menu-title{
      list-style: none;
      color: #2563eb;
      font-size: 15px;
      font-weight: 700;
      padding: 13px 15px;
      border-radius: 14px;
      background: #eff6ff;
      cursor: pointer;
      user-select: none;
    }

    .menu-title::-webkit-details-marker{
      display: none;
    }

    .menu-title::after{
      content: 'v';
      float: right;
      font-size: 12px;
      transition: 0.2s;
    }

    .menu-dropdown[open] .menu-title::after{
      transform: rotate(180deg);
    }

    .submenu{
      display: grid;
      gap: 6px;
      padding-left: 12px;
    }

    .submenu .menu-link{
      font-size: 14px;
      padding: 11px 14px;
    }

    .main-content{
      flex: 1;
      padding: 32px;
    }

    .topbar{
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 32px;
    }

    .topbar-left{
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .sidebar-toggle{
      width: 44px;
      height: 44px;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      background: #ffffff;
      color: #2563eb;
      font-size: 22px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(15,23,42,0.06);
    }

    .topbar h1{
      font-size: 34px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .topbar p{
      color: #64748b;
      font-size: 15px;
    }

    .logout-form{
      margin: 0;
    }

    .admin-badge{
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 12px 18px;
      color: #2563eb;
      font-weight: 600;
      box-shadow: 0 8px 24px rgba(15,23,42,0.06);
      white-space: nowrap;
      cursor: pointer;
      transition: 0.2s;
    }

    .admin-badge:hover{
      border-color: #fecaca;
      color: #dc2626;
      background: #fef2f2;
    }

    .logout-modal{
      position: fixed;
      inset: 0;
      z-index: 1200;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(15,23,42,0.45);
    }

    .logout-modal.show{
      display: flex;
    }

    .logout-box{
      width: min(420px, 100%);
      background: #ffffff;
      border-radius: 22px;
      padding: 28px;
      box-shadow: 0 24px 50px rgba(15,23,42,0.25);
      animation: modalShow 0.25s ease;
    }

    .logout-box h2{
      font-size: 22px;
      margin-bottom: 8px;
    }

    .logout-box p{
      color: #64748b;
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 24px;
    }

    .logout-actions{
      display: flex;
      gap: 12px;
      justify-content: flex-end;
    }

    .btn-cancel,
    .btn-logout{
      height: 46px;
      border-radius: 14px;
      padding: 0 18px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-cancel{
      border: 1px solid #e2e8f0;
      background: #ffffff;
      color: #475569;
    }

    .btn-logout{
      border: none;
      background: #dc2626;
      color: #ffffff;
    }

    .delete-button{
      border: none;
      border-radius: 12px;
      background: #fef2f2;
      color: #dc2626;
      padding: 10px 14px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
    }

    .delete-button:hover{
      background: #dc2626;
      color: #ffffff;
    }

    @keyframes modalShow{
      from{
        opacity: 0;
        transform: translateY(-10px);
      }
      to{
        opacity: 1;
        transform: translateY(0);
      }
    }

    .table-card{
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      box-shadow: 0 12px 30px rgba(15,23,42,0.08);
      overflow: hidden;
    }

    .table-toolbar{
      padding: 22px;
      border-bottom: 1px solid #e2e8f0;
      background: #ffffff;
    }

    .search-input{
      width: 100%;
      height: 52px;
      border: 1px solid #dbe2ea;
      border-radius: 14px;
      padding: 0 16px;
      font-size: 14px;
      outline: none;
    }

    .search-input:focus{
      border-color: #2563eb;
      box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
    }

    .table-wrap{
      width: 100%;
      overflow-x: auto;
    }

    table{
      width: 100%;
      border-collapse: collapse;
      min-width: 720px;
    }

    th,
    td{
      padding: 18px 22px;
      text-align: left;
      border-bottom: 1px solid #e2e8f0;
      font-size: 14px;
    }

    th{
      background: #f8fafc;
      color: #475569;
      font-weight: 700;
    }

    .role-header{
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .role-filter{
      height: 36px;
      border: 1px solid #dbe2ea;
      border-radius: 10px;
      background: #ffffff;
      color: #475569;
      padding: 0 10px;
      font-size: 13px;
      font-weight: 600;
      outline: none;
      cursor: pointer;
    }

    .role-filter:focus{
      border-color: #2563eb;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }

    td{
      color: #0f172a;
      font-weight: 500;
    }

    tr:last-child td{
      border-bottom: none;
    }

    .role-badge{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 96px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #eff6ff;
      color: #2563eb;
      font-size: 13px;
      font-weight: 700;
      text-transform: capitalize;
    }

    .empty-state{
      padding: 32px;
      text-align: center;
      color: #64748b;
      font-size: 15px;
    }

    .pagination{
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 18px 22px;
      border-top: 1px solid #e2e8f0;
      background: #ffffff;
    }

    .page-button{
      height: 42px;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background: #ffffff;
      color: #2563eb;
      padding: 0 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .page-button:disabled{
      color: #94a3b8;
      cursor: not-allowed;
      background: #f8fafc;
    }

    .page-info{
      color: #64748b;
      font-size: 14px;
      font-weight: 600;
    }

    @media(max-width: 768px){
      .admin-page{
        flex-direction: column;
      }

      .sidebar{
        width: 100%;
        padding: 20px;
        border-right: none;
        border-bottom: 1px solid #e2e8f0;
      }

      .admin-page.sidebar-collapsed .sidebar{
        width: 100%;
        height: 0;
        padding-top: 0;
        padding-bottom: 0;
        border-bottom: none;
      }

      .brand{
        margin-bottom: 18px;
      }

      .main-content{
        padding: 22px;
      }

      .topbar{
        align-items: flex-start;
        flex-direction: column;
      }

      .topbar h1{
        font-size: 28px;
      }

    }

    @media(max-width: 480px){
      .main-content{
        padding: 16px;
      }
    }
  </style>
</head>
<body>
  <main class="admin-page" id="adminPage">
    <aside class="sidebar">
      <div class="brand">Admin Panel</div>
      <nav class="menu">
        <a href="/dashboard" class="menu-link">Dashboard</a>
        <details class="menu-dropdown" open>
          <summary class="menu-title">Akun</summary>
          <div class="submenu">
            <a href="/admin/buat-akun" class="menu-link">Buat Akun</a>
            <a href="/admin/daftar-akun" class="menu-link active">Daftar Akun</a>
          </div>
        </details>
      </nav>
    </aside>

    <section class="main-content">
      <div class="topbar">
        <div class="topbar-left">
          <button type="button" class="sidebar-toggle" id="sidebarToggle">☰</button>
          <div>
            <h1>Daftar Akun</h1>
            <p>Daftar akun yang terdaftar</p>
          </div>
        </div>
        <form action="/logout" method="POST" class="logout-form">
          <button type="submit" class="admin-badge">Admin | Logout</button>
        </form>
      </div>

      <div class="table-card">
        <div class="table-toolbar">
          <input
            type="text"
            id="accountSearch"
            class="search-input"
            value="<%= search || '' %>"
            placeholder="Cari email atau role"
          >
        </div>

        <% if (users && users.length > 0) { %>
          <div class="table-wrap">
            <table id="accountTable">
              <thead>
                <tr>
                  <th>No</th>
                  <th>Email</th>
                  <th>
                    <div class="role-header">
                      <span>Role</span>
                      <select id="roleFilter" class="role-filter">
                        <option value="">Semua</option>
                        <option value="admin">Admin</option>
                        <option value="mahasiswa">Mahasiswa</option>
                        <option value="dosen">Dosen</option>
                        <option value="satpam">Satpam</option>
                        <option value="tendik">Tendik</option>
                        <option value="plp">PLP</option>
                      </select>
                    </div>
                  </th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach((user, index) => { %>
                  <tr class="account-row" data-role="<%= user.role %>">
                    <td><%= index + 1 %></td>
                    <td><%= user.email %></td>
                    <td><span class="role-badge"><%= user.role %></span></td>
                    <td>
                      <% if (user.role !== 'admin') { %>
                        <form action="/admin/users/delete/<%= user.id_user %>" method="POST" class="delete-form">
                          <input type="hidden" name="_method" value="DELETE">
                          <button type="submit" class="delete-button" data-email="<%= user.email %>">Hapus</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="empty-state" id="searchEmpty" style="display: none;">Akun tidak ditemukan.</div>
          <div class="pagination">
            <button type="button" class="page-button" id="prevPage">Back</button>
            <span class="page-info" id="pageInfo">1 / 1</span>
            <button type="button" class="page-button" id="nextPage">Next</button>
          </div>
        <% } else { %>
          <div class="empty-state">Belum ada akun yang terdaftar.</div>
        <% } %>
      </div>
    </section>

    <div class="logout-modal" id="logoutModal">
      <div class="logout-box">
        <h2>Logout</h2>
        <p>Apakah Anda mau logout dari halaman admin?</p>
        <div class="logout-actions">
          <button type="button" class="btn-cancel" id="cancelLogout">Batal</button>
          <button type="button" class="btn-logout" id="confirmLogout">Logout</button>
        </div>
      </div>
    </div>

    <div class="logout-modal" id="deleteModal">
      <div class="logout-box">
        <h2>Hapus Akun</h2>
        <p>Apakah Anda yakin mau menghapus <strong id="deleteUserName"></strong>?</p>
        <div class="logout-actions">
          <button type="button" class="btn-cancel" id="cancelDelete">Batal</button>
          <button type="button" class="btn-logout" id="confirmDelete">Hapus</button>
        </div>
      </div>
    </div>
  </main>

  <script>
    const searchInput = document.getElementById('accountSearch');
    const roleFilter = document.getElementById('roleFilter');
    const rows = document.querySelectorAll('.account-row');
    const searchEmpty = document.getElementById('searchEmpty');
    const prevPage = document.getElementById('prevPage');
    const nextPage = document.getElementById('nextPage');
    const pageInfo = document.getElementById('pageInfo');
    const adminPage = document.getElementById('adminPage');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const perPage = 10;
    let currentPage = 1;
    let filteredRows = Array.from(rows);

    if (localStorage.getItem('sidebarCollapsed') === 'true') {
      adminPage.classList.add('sidebar-collapsed');
    }

    sidebarToggle.addEventListener('click', () => {
      adminPage.classList.toggle('sidebar-collapsed');
      localStorage.setItem('sidebarCollapsed', adminPage.classList.contains('sidebar-collapsed'));
    });

    const renderPage = () => {
      const totalPages = Math.max(Math.ceil(filteredRows.length / perPage), 1);

      if (currentPage > totalPages) {
        currentPage = totalPages;
      }

      rows.forEach((row) => {
        row.style.display = 'none';
      });

      filteredRows
        .slice((currentPage - 1) * perPage, currentPage * perPage)
        .forEach((row) => {
          row.style.display = '';
        });

      if (searchEmpty) {
        searchEmpty.style.display = filteredRows.length === 0 ? 'block' : 'none';
      }

      if (pageInfo) {
        pageInfo.textContent = currentPage + ' / ' + totalPages;
      }

      if (prevPage) {
        prevPage.disabled = currentPage === 1;
      }

      if (nextPage) {
        nextPage.disabled = currentPage === totalPages || filteredRows.length === 0;
      }
    };

    const filterAccounts = () => {
      const keyword = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const selectedRole = roleFilter ? roleFilter.value : '';
      filteredRows = [];

      rows.forEach((row) => {
        const rowText = row.textContent.toLowerCase();
        const rowRole = row.dataset.role;
        const isSearchMatch = rowText.includes(keyword);
        const isRoleMatch = !selectedRole || rowRole === selectedRole;
        row.style.display = 'none';

        if (isSearchMatch && isRoleMatch) {
          filteredRows.push(row);
        }
      });

      currentPage = 1;
      renderPage();
    };

    if (searchInput) {
      searchInput.addEventListener('input', filterAccounts);
    }

    if (roleFilter) {
      roleFilter.addEventListener('change', filterAccounts);
    }

    filterAccounts();

    if (prevPage && nextPage) {
      prevPage.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage -= 1;
          renderPage();
        }
      });

      nextPage.addEventListener('click', () => {
        const totalPages = Math.max(Math.ceil(filteredRows.length / perPage), 1);
        if (currentPage < totalPages) {
          currentPage += 1;
          renderPage();
        }
      });
    }

    const logoutForm = document.querySelector('.logout-form');
    const logoutModal = document.getElementById('logoutModal');
    const cancelLogout = document.getElementById('cancelLogout');
    const confirmLogout = document.getElementById('confirmLogout');
    const deleteForms = document.querySelectorAll('.delete-form');
    const deleteModal = document.getElementById('deleteModal');
    const deleteUserName = document.getElementById('deleteUserName');
    const cancelDelete = document.getElementById('cancelDelete');
    const confirmDelete = document.getElementById('confirmDelete');
    let selectedDeleteForm = null;

    logoutForm.addEventListener('submit', (event) => {
      event.preventDefault();
      logoutModal.classList.add('show');
    });

    cancelLogout.addEventListener('click', () => {
      logoutModal.classList.remove('show');
    });

    confirmLogout.addEventListener('click', () => {
      logoutForm.submit();
    });

    deleteForms.forEach((form) => {
      form.addEventListener('submit', (event) => {
        event.preventDefault();

        selectedDeleteForm = form;
        deleteUserName.textContent = form.querySelector('.delete-button').dataset.email;
        deleteModal.classList.add('show');
      });
    });

    cancelDelete.addEventListener('click', () => {
      deleteModal.classList.remove('show');
      selectedDeleteForm = null;
    });

    confirmDelete.addEventListener('click', () => {
      if (selectedDeleteForm) {
        selectedDeleteForm.submit();
      }
    });
  </script>
</body>
</html>
