<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Login</title>

  <!-- GOOGLE FONT -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>

    *{
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body{
      min-height: 100vh;
      background: #f1f5f9;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .login-container{
      width: 100%;
      max-width: 520px;
    }

    .login-box{
      background: #ffffff;
      border-radius: 30px;
      padding: 60px 45px;
      box-shadow: 0 10px 35px rgba(0,0,0,0.08);
    }

    .popup-alert{
      position: fixed;
      top: 24px;
      right: 24px;
      z-index: 1000;
      width: min(380px, calc(100% - 32px));
      padding: 16px 18px;
      border-radius: 18px;
      color: #ffffff;
      box-shadow: 0 18px 35px rgba(15,23,42,0.22);
      display: flex;
      align-items: center;
      gap: 12px;
      animation: popupSlide 0.35s ease, popupHide 0.35s ease 4.6s forwards;
    }

    .popup-alert.email-error,
    .popup-alert.password-error{
      background: linear-gradient(135deg, #ef4444, #b91c1c);
    }

    .popup-icon{
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,0.22);
      display: flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      font-weight: 700;
      font-size: 22px;
    }

    .popup-text strong{
      display: block;
      font-size: 15px;
      margin-bottom: 2px;
    }

    .popup-text span{
      display: block;
      font-size: 13px;
      line-height: 1.4;
      opacity: 0.95;
    }

    .title{
      text-align: center;
      margin-bottom: 30px;
    }

    .title h1{
      font-size: 48px;
      color: #0f172a;
      margin-bottom: 10px;
    }

    .title p{
      color: #64748b;
      font-size: 17px;
    }

    .form-group{
      margin-bottom: 25px;
    }

    .form-group label{
      display: block;
      margin-bottom: 12px;
      font-size: 16px;
      font-weight: 600;
      color: #0f172a;
    }

    .input-box input{
      width: 100%;
      height: 62px;
      border: 1px solid #dbe2ea;
      border-radius: 18px;
      padding: 0 20px;
      font-size: 16px;
      outline: none;
      transition: 0.3s;
    }

    .input-box input:focus{
      border-color: #2563eb;
      box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
    }

    /* INPUT ERROR */
    .input-error{
      border: 2px solid #dc2626 !important;
      background: #fef2f2;
    }

    .btn-login{
      width: 100%;
      height: 62px;
      border: none;
      border-radius: 18px;
      background: linear-gradient(to right, #2563eb, #1d4ed8);
      color: #ffffff;
      font-size: 18px;
      font-weight: 600;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn-login:hover{
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(37,99,235,0.2);
    }

    @keyframes popupSlide{
      from{
        opacity: 0;
        transform: translateY(-12px);
      }
      to{
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes popupHide{
      to{
        opacity: 0;
        transform: translateY(-12px);
        visibility: hidden;
      }
    }

    /* RESPONSIVE */
    @media(max-width: 768px){

      .login-box{
        padding: 40px 25px;
        border-radius: 24px;
      }

      .title h1{
        font-size: 36px;
      }

      .title p{
        font-size: 15px;
      }

      .input-box input{
        height: 55px;
        font-size: 14px;
      }

      .btn-login{
        height: 55px;
        font-size: 16px;
      }

      .popup-alert{
        top: 16px;
        right: 16px;
        left: 16px;
        width: auto;
      }

    }

    @media(max-width: 480px){

      body{
        padding: 15px;
      }

      .login-box{
        padding: 30px 18px;
      }

      .title h1{
        font-size: 30px;
      }

    }

  </style>
</head>

<body>
  <%
    const errorMessage = Array.isArray(error) ? error[0] : error;
    const isEmailError = errorMessage === 'Email tidak ditemukan';
    const isPasswordError = errorMessage === 'Kata sandi salah';
  %>

  <% if (isEmailError || isPasswordError) { %>
    <div class="popup-alert <%= isEmailError ? 'email-error' : 'password-error' %>">
      <div class="popup-icon">!</div>
      <div class="popup-text">
        <strong><%= errorMessage %></strong>
        <span>
          <%= isEmailError
            ? 'Email belum terdaftar sebagai admin.'
            : 'Periksa kembali kata sandi Anda.' %>
        </span>
      </div>
    </div>
  <% } %>

  <div class="login-container">

    <div class="login-box">

      <div class="title">
        <h1>Login Admin</h1>
        <p>Masuk untuk melanjutkan ke akun Anda.</p>
      </div>

      <form action="/login" method="POST">

        <!-- EMAIL -->
        <div class="form-group">

          <label>Email</label>

          <div class="input-box">
            <input 
              type="text"
              name="email"
              placeholder="Masukkan email"
              required

              class="<%= isEmailError ? 'input-error' : '' %>"
            >
          </div>

        </div>

        <!-- PASSWORD -->
        <div class="form-group">

          <label>Kata Sandi</label>

          <div class="input-box">
            <input 
              type="password"
              name="password"
              placeholder="Masukkan kata sandi"
              required

              class="<%= isPasswordError ? 'input-error' : '' %>"
            >
          </div>

        </div>

        <button type="submit" class="btn-login">
          Masuk
        </button>

      </form>

    </div>

  </div>

</body>
</html>
